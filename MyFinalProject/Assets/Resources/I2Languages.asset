    - Term: CoinsChangeValue
      TermType: 0
      Description: 
      Languages:
      - 'Click coins to change <color=red>Dice Value</color>.

        <color=red>(Click
        to close)</color>'
      - "\u70B9\u51FB\u91D1\u5E01\u53EF\u66F4\u6539 <color=red>\u9AB0\u5B50\u70B9\u6570</color>\u3002\n<color=red>\uFF08\u70B9\u51FB\u5173\u95ED\uFF09</color>"
