    - Term: Tutorial_IntroEnd
      TermType: 0
      Description: 
      Languages:
      - 'Tutorial Completed!

        <color=red>Click Here: Begin Your Journey.
        </color>'
      - "\u6559\u7A0B\u5B8C\u6210\uFF01\n<color=red>\u70B9\u51FB\u8FD9\u91CC\uFF1A\u5F00\u59CB\u4F60\u7684\u65C5\u7A0B\u3002</color>"
      Flags: 0000
      Languages_Touch: []
    - Term: CheckDiceAgain.
      TermType: 0
      Description: 
      Languages:
      - 'Check Dice again.

        <color=red>(Click to Close) </color>'
      - "\u518D\u6B21\u68C0\u67E5\u9AB0\u5B50\u3002\n<color=red>\uFF08\u70B9\u51FB\u5173\u95ED\uFF09</color>"
      Flags: 0000
      Languages_Touch: []
    - Term: Tutorial_SafeReward
      TermType: 0
      Description: 
      Languages:
      - "Safe! Click get 2 Rewards: \n<color=red>10 Coins\n1 Dice Probability Change</color>.\n<color=red>(Click
        to close)</color>"
      - "\u5B89\u5168\u7ED3\u675F\u672C\u56DE\u5408\uFF01\n\u70B9\u51FB\u9886\u53D6
        2 \u9879\u5956\u52B1\uFF1A\n<color=red> 10 \u91D1\u5E01\u548C1\u6B21\u9AB0\u5B50\u6982\u7387\u63D0\u5347</color>\n<color=red>\uFF08\u70B9\u51FB\u5173\u95ED\uFF09</color>"
      Flags: 0000
      Languages_Touch: []
    - Term: Tutorial_PreparationStage
      TermType: 0
      Description: 
      Languages:
      - "Preparation Stage:\n1. Click <color=red>4 </color>to pray for good weather.\n2.
        Click  <color=red>5 </color> to select the number of scouts/total for this
        round. \n3. Click <color=red> 6 </color>to start moving!\n<color=red>(Click
        to close)</color>"
      - "\u51C6\u5907\u9636\u6BB5\uFF1A\n1. \u70B9\u51FB <color=red> 4 </color> \u7948\u6C42\u597D\u5929\u6C14\u3002\n2.
        \u70B9\u51FB <color=red> 5 </color> \u9009\u62E9\u672C\u56DE\u5408 \u4FA6\u5BDF\u9E1F/\u4E3B\u529B\u90E8\u961F
        \u7684\u6BD4\u4F8B\u3002\n3. \u70B9\u51FB <color=red> 6 </color> \u5F00\u59CB\u884C\u52A8\uFF01\n<color=red>\uFF08\u70B9\u51FB\u5173\u95ED\uFF09</color>"
      Flags: 0000
      Languages_Touch: []
    - Term: Tutorial_ClickDiceImage
      TermType: 0
      Description: 
      Languages:
      - '<color=red>Click Dice Image</color> to view your environment.

        <color=red>(Click
        to close)</color>'
      - "\u70B9\u51FB<color=red>\u201C\u9AB0\u5B50</color>\u201D\u67E5\u770B\u60A8\u7684\u73AF\u5883\u3002\n<color=red>\uFF08\u70B9\u51FB\u5173\u95ED\uFF09</color>"
      Flags: 0000
      Languages_Touch: []
    - Term: Tutorial_Calculating
      TermType: 0
      Description: 
      Languages:
      - 'Calculating...

        <color=red>(Click to close)</color>'
      - "\u6B63\u5728\u8BA1\u7B97\u2026\u2026\n<color=red>\uFF08\u70B9\u51FB\u5173\u95ED\uFF09</color>"
      Flags: 0000
      Languages_Touch: []
